# Local config for the tunebook generators (loaded by tunebook-lib.ts).
# Real shell environment variables override these. ~/ is expanded.

# Where the tune data lives (expects abc/ and sets/ subfolders):
VAULT_DIR=~/manda-general-knowledge-vault

# Where generated PDFs are written (defaults to VAULT_DIR if unset):
OUTPUT_DIR=~/manda-general-knowledge-vault
